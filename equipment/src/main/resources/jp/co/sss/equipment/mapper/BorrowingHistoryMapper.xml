<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" 
 "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<!-- mapperインターフェスと修飾名を一致させる -->
<mapper
	namespace="jp.co.sss.equipment.mapper.BorrowingHistoryMapper">
	<!-- DTOマッピング -->
	<resultMap id="BorrowingHistoryResultMap"
		type="jp.co.sss.equipment.dto.BorrowingHistoryDto">

		<result column="stock_code" property="stockCode" />
		<result column="category_name" property="categoryName" />
		<result column="product_name" property="productName" />
		<result column="staffName" property="staffName" />
		<result column="start_date" property="startDate" />
		<result column="return_date" property="returnDate" />
		<result column="limit_date" property="limitDate" />
		<result column="ownership_type" property="ownershipType" />
		<result column="deleted_label" property="deletedLabel" />

	</resultMap>

	<!-- 履歴取得 -->
	<!-- 履歴取得 -->
	<select id="findBorrowingHistory"
		parameterType="jp.co.sss.equipment.form.BorrowingHistorySearchForm"
		resultMap="BorrowingHistoryResultMap">

		SELECT
		stock_code,
		category_name,
		product_name,
		staffName,
		start_date,
		return_date,
		limit_date,
		ownership_type,
		deleted_label
		FROM
		borrow_history_view

		<where>
			<!-- 部品コード、部品名、貸出者名は部分一致 -->
			<if test="stockCode != null and stockCode != ''">
				AND stock_code LIKE CONCAT('%', #{stockCode}, '%')
			</if>

			<if test="categoryName != null and categoryName != ''">
				AND category_name LIKE CONCAT('%', #{categoryName}, '%')
			</if>

			<if test="productName != null and productName != ''">
				AND product_name LIKE CONCAT('%', #{productName}, '%')
			</if>

			<if test="staffName != null and staffName != ''">
				AND staffName LIKE CONCAT('%', #{staffName}, '%')
			</if>

			<!-- 日付は範囲指定 -->
			<if test="fromDate != null">
				AND start_date &gt;= #{fromDate}
			</if>

			<if test="toDate != null">
				AND start_date &lt;= #{toDate}
			</if>

			<if test="returnFromDate != null">
				AND return_date &gt;= #{returnFromDate}
			</if>

			<if test="returnToDate != null">
				AND return_date &lt;= #{returnToDate}
			</if>

			<!-- 分類（チェックボックス複数） -->
			<if test="ownershipTypes != null and ownershipTypes.size() > 0">
				AND ownership_type IN
				<foreach collection="ownershipTypes" item="t" open="("
					separator="," close=")">
					#{t}
				</foreach>
			</if>

			<!-- 削除（チェックボックス複数） -->
			<if test="deletedStatuses != null and deletedStatuses.size() > 0">
				AND (
				<foreach collection="deletedStatuses" item="d"
					separator=" OR ">
					<choose>
						<!-- 「未削除」が選択された場合は、deleted_labelがNULLまたは空文字のレコードを対象とする -->
						<when test="d == '未削除'">
							(deleted_label IS NULL OR deleted_label = '')
						</when>
						<otherwise>
							(deleted_label = '削除')
						</otherwise>
					</choose>
				</foreach>
				)
			</if>

			<if test="staffNo != null">
				AND staff_no = #{staffNo}
			</if>

		</where>

		<!-- デフォルト返却日DESC＋動的ソート -->
		ORDER BY
		<choose>
			<when test="sortKey != null and sortKey != ''">
				<choose>
					<when test="sortKey == 'stockCode'">stock_code</when>
					<when test="sortKey == 'categoryName'">category_name</when>
					<when test="sortKey == 'productName'">product_name</when>
					<when test="sortKey == 'staffName'">staffName</when>
					<when test="sortKey == 'startDate'">start_date</when>
					<when test="sortKey == 'returnDate'">return_date</when>
					<when test="sortKey == 'limitDate'">limit_date</when>
					<when test="sortKey == 'ownershipType'">ownership_type</when>
					<when test="sortKey == 'deletedLabel'">deleted_label</when>
					<otherwise>return_date</otherwise>
				</choose>

				<choose>
					<!-- ソート方向の指定がない場合は返却日DESC -->
					<when test="sortDir == 'asc'"> ASC</when>
					<otherwise> DESC</otherwise>
				</choose>
			</when>

			<otherwise>
				return_date IS NULL ASC, return_date DESC
			</otherwise>
		</choose>

	</select>

</mapper>